# Copy to staging.env / prod.env (sibling of this file) and fill in real
# values. These files are gitignored. Pass to scripts/seed-keyvault.sh:
#
#   scripts/seed-keyvault.sh <vault-name> infra/secrets/staging.env
#
# Keys must match the Bicep keyVaultSecretNames object (uppercase here, the
# script kebab-cases them: DATABASE_URL -> database-url, etc.).

DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RESEND_API_KEY=
RESEND_EMAIL_FROM=
RESEND_EMAIL_REPLY_TO=
AI_GATEWAY_API_KEY=
