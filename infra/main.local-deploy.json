{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "1557857462332872643"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for this environment."
      }
    },
    "projectName": {
      "type": "string",
      "defaultValue": "sycomlearn",
      "metadata": {
        "description": "Project name prefix used in resource naming."
      }
    },
    "environmentName": {
      "type": "string",
      "defaultValue": "prod",
      "metadata": {
        "description": "Environment name, usually prod."
      }
    },
    "deployApps": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Deploy only shared infrastructure when false, or infrastructure plus the app when true."
      }
    },
    "containerRegistryName": {
      "type": "string",
      "metadata": {
        "description": "Globally unique Azure Container Registry name."
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Globally unique Azure Key Vault name."
      }
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "defaultValue": "[format('{0}-{1}-logs', parameters('projectName'), parameters('environmentName'))]",
      "metadata": {
        "description": "Log Analytics workspace name."
      }
    },
    "containerAppsEnvironmentName": {
      "type": "string",
      "defaultValue": "[format('{0}-{1}-cae', parameters('projectName'), parameters('environmentName'))]",
      "metadata": {
        "description": "Container Apps environment name."
      }
    },
    "appName": {
      "type": "string",
      "defaultValue": "[format('{0}-{1}-app', parameters('projectName'), parameters('environmentName'))]",
      "metadata": {
        "description": "Container App name. Both containers live in this single app."
      }
    },
    "dashboardImage": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
      "metadata": {
        "description": "Dashboard image reference in ACR."
      }
    },
    "serverImage": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
      "metadata": {
        "description": "Server image reference in ACR."
      }
    },
    "dashboardUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Public app URL for this environment."
      }
    },
    "websiteUrl": {
      "type": "string",
      "defaultValue": "https://sycomsolutions.com",
      "metadata": {
        "description": "Optional public website URL used by server-side links."
      }
    },
    "corsOrigins": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Allowed browser origins for the server."
      }
    },
    "dashboardTargetPort": {
      "type": "int",
      "defaultValue": 3000,
      "metadata": {
        "description": "Dashboard container port (the only ingress)."
      }
    },
    "serverTargetPort": {
      "type": "int",
      "defaultValue": 3001,
      "metadata": {
        "description": "Server container port (loopback only)."
      }
    },
    "appMinReplicas": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "Minimum app replicas."
      }
    },
    "appMaxReplicas": {
      "type": "int",
      "defaultValue": 2,
      "metadata": {
        "description": "Maximum app replicas."
      }
    },
    "keyVaultAdminObjectId": {
      "type": "string",
      "metadata": {
        "description": "Object ID that should get Key Vault secret permissions."
      }
    },
    "debugPerformance": {
      "type": "string",
      "defaultValue": "false",
      "allowedValues": ["true", "false"]
    },
    "deployPostgres": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Provision Azure Database for PostgreSQL Flexible Server. Set false for Neon or other external Postgres."
      }
    },
    "databaseUrl": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "External Postgres connection string when deployPostgres is false (e.g. Neon). Stored in Key Vault as database-url."
      }
    },
    "postgresServerName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Globally unique PostgreSQL flexible server name."
      }
    },
    "postgresDatabaseName": {
      "type": "string",
      "defaultValue": "sycom",
      "metadata": {
        "description": "Application database name on the flexible server."
      }
    },
    "postgresAdminLogin": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "PostgreSQL administrator login."
      }
    },
    "postgresAdminPassword": {
      "type": "securestring",
      "defaultValue": ""
    },
    "postgresSkuName": {
      "type": "string",
      "defaultValue": "Standard_B1ms",
      "metadata": {
        "description": "Flexible server SKU name."
      }
    },
    "postgresSkuTier": {
      "type": "string",
      "defaultValue": "Burstable",
      "metadata": {
        "description": "Flexible server SKU tier."
      }
    },
    "postgresStorageGb": {
      "type": "int",
      "defaultValue": 32,
      "metadata": {
        "description": "Storage size in GB."
      }
    },
    "postgresVersion": {
      "type": "string",
      "defaultValue": "18",
      "metadata": {
        "description": "PostgreSQL major version."
      }
    },
    "betterAuthSecret": {
      "type": "securestring",
      "defaultValue": ""
    },
    "betterAuthApiKey": {
      "type": "securestring",
      "defaultValue": ""
    },
    "googleClientId": {
      "type": "securestring",
      "defaultValue": ""
    },
    "googleClientSecret": {
      "type": "securestring",
      "defaultValue": ""
    },
    "linkedinClientId": {
      "type": "securestring",
      "defaultValue": ""
    },
    "linkedinClientSecret": {
      "type": "securestring",
      "defaultValue": ""
    },
    "cloudinaryCloudName": {
      "type": "securestring",
      "defaultValue": ""
    },
    "cloudinaryApiKey": {
      "type": "securestring",
      "defaultValue": ""
    },
    "cloudinaryApiSecret": {
      "type": "securestring",
      "defaultValue": ""
    },
    "resendApiKey": {
      "type": "securestring",
      "defaultValue": ""
    },
    "resendEmailFrom": {
      "type": "securestring",
      "defaultValue": ""
    },
    "resendEmailReplyTo": {
      "type": "securestring",
      "defaultValue": ""
    },
    "aiGatewayApiKey": {
      "type": "securestring",
      "defaultValue": ""
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Common tags applied to created resources."
      }
    }
  },
  "variables": {
    "mergedTags": "[union(parameters('tags'), createObject('project', parameters('projectName')))]",
    "defaultCorsOrigins": "[if(empty(parameters('websiteUrl')), createArray(parameters('dashboardUrl')), createArray(parameters('dashboardUrl'), parameters('websiteUrl')))]",
    "effectiveCorsOrigins": "[if(greater(length(parameters('corsOrigins')), 0), parameters('corsOrigins'), variables('defaultCorsOrigins'))]",
    "corsOriginValue": "[join(variables('effectiveCorsOrigins'), ',')]",
    "internalServerUrl": "[format('http://localhost:{0}', parameters('serverTargetPort'))]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[parameters('logAnalyticsWorkspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "retentionInDays": 30,
        "features": {
          "enableLogAccessUsingOnlyResourcePermissions": true
        }
      },
      "sku": {
        "name": "PerGB2018"
      },
      "tags": "[variables('mergedTags')]"
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[parameters('containerRegistryName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": true,
        "publicNetworkAccess": "Enabled"
      },
      "tags": "[variables('mergedTags')]"
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-02-01",
      "name": "[parameters('keyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "enableRbacAuthorization": false,
        "enablePurgeProtection": true,
        "enabledForDeployment": false,
        "enabledForDiskEncryption": false,
        "enabledForTemplateDeployment": false,
        "publicNetworkAccess": "Enabled",
        "tenantId": "[subscription().tenantId]",
        "accessPolicies": [
          {
            "tenantId": "[subscription().tenantId]",
            "objectId": "[parameters('keyVaultAdminObjectId')]",
            "permissions": {
              "secrets": ["Get", "List", "Set", "Delete", "Recover", "Backup", "Restore"]
            }
          }
        ],
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "softDeleteRetentionInDays": 90
      },
      "tags": "[variables('mergedTags')]"
    },
    {
      "condition": "[and(not(parameters('deployPostgres')), not(empty(parameters('databaseUrl'))))]",
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-02-01",
      "name": "[format('{0}/{1}', parameters('keyVaultName'), 'database-url')]",
      "properties": {
        "value": "[parameters('databaseUrl')]"
      },
      "dependsOn": ["[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"]
    },
    {
      "condition": "[parameters('deployPostgres')]",
      "type": "Microsoft.DBforPostgreSQL/flexibleServers",
      "apiVersion": "2024-08-01",
      "name": "[parameters('postgresServerName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('postgresSkuName')]",
        "tier": "[parameters('postgresSkuTier')]"
      },
      "properties": {
        "version": "[parameters('postgresVersion')]",
        "administratorLogin": "[parameters('postgresAdminLogin')]",
        "administratorLoginPassword": "[parameters('postgresAdminPassword')]",
        "storage": {
          "storageSizeGB": "[parameters('postgresStorageGb')]"
        },
        "backup": {
          "backupRetentionDays": 7,
          "geoRedundantBackup": "Disabled"
        },
        "network": {
          "publicNetworkAccess": "Enabled"
        },
        "highAvailability": {
          "mode": "Disabled"
        }
      },
      "tags": "[variables('mergedTags')]"
    },
    {
      "condition": "[parameters('deployPostgres')]",
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2024-08-01",
      "name": "[format('{0}/{1}', parameters('postgresServerName'), parameters('postgresDatabaseName'))]",
      "properties": {
        "charset": "UTF8",
        "collation": "en_US.utf8"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('postgresServerName'))]"
      ]
    },
    {
      "condition": "[parameters('deployPostgres')]",
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
      "apiVersion": "2024-08-01",
      "name": "[format('{0}/{1}', parameters('postgresServerName'), 'AllowAllAzureServices')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('postgresServerName'))]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[parameters('containerAppsEnvironmentName')]",
      "location": "[parameters('location')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName')), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName')), '2023-09-01').primarySharedKey]"
          }
        }
      },
      "tags": "[variables('mergedTags')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName'))]"
      ]
    },
    {
      "condition": "[parameters('deployApps')]",
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[parameters('appName')]",
      "location": "[parameters('location')]",
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "allowInsecure": false,
            "external": true,
            "targetPort": "[parameters('dashboardTargetPort')]",
            "transport": "auto",
            "traffic": [
              {
                "latestRevision": true,
                "weight": 100
              }
            ]
          },
          "registries": [
            {
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName')), '2023-07-01').loginServer]",
              "username": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName')), '2023-07-01').username]",
              "passwordSecretRef": "acr-password"
            }
          ],
          "secrets": [
            {
              "name": "acr-password",
              "value": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName')), '2023-07-01').passwords[0].value]"
            },
            {
              "name": "database-url",
              "value": "[if(parameters('deployPostgres'), format('postgresql://{0}:{1}@{2}:5432/{3}?sslmode=require', parameters('postgresAdminLogin'), uriComponent(parameters('postgresAdminPassword')), reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('postgresServerName')), '2024-08-01').fullyQualifiedDomainName, parameters('postgresDatabaseName')), parameters('databaseUrl'))]"
            },
            {
              "name": "better-auth-secret",
              "value": "[parameters('betterAuthSecret')]"
            },
            {
              "name": "better-auth-api-key",
              "value": "[parameters('betterAuthApiKey')]"
            },
            {
              "name": "google-client-id",
              "value": "[parameters('googleClientId')]"
            },
            {
              "name": "google-client-secret",
              "value": "[parameters('googleClientSecret')]"
            },
            {
              "name": "linkedin-client-id",
              "value": "[parameters('linkedinClientId')]"
            },
            {
              "name": "linkedin-client-secret",
              "value": "[parameters('linkedinClientSecret')]"
            },
            {
              "name": "cloudinary-cloud-name",
              "value": "[parameters('cloudinaryCloudName')]"
            },
            {
              "name": "cloudinary-api-key",
              "value": "[parameters('cloudinaryApiKey')]"
            },
            {
              "name": "cloudinary-api-secret",
              "value": "[parameters('cloudinaryApiSecret')]"
            },
            {
              "name": "resend-api-key",
              "value": "[parameters('resendApiKey')]"
            },
            {
              "name": "resend-email-from",
              "value": "[parameters('resendEmailFrom')]"
            },
            {
              "name": "resend-email-reply-to",
              "value": "[parameters('resendEmailReplyTo')]"
            },
            {
              "name": "ai-gateway-api-key",
              "value": "[parameters('aiGatewayApiKey')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "dashboard",
              "image": "[parameters('dashboardImage')]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              },
              "env": [
                {
                  "name": "INTERNAL_SERVER_URL",
                  "value": "[variables('internalServerUrl')]"
                }
              ],
              "probes": [
                {
                  "type": "Startup",
                  "httpGet": {
                    "path": "/health",
                    "port": "[parameters('dashboardTargetPort')]"
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10,
                  "timeoutSeconds": 5,
                  "failureThreshold": 12
                },
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/health",
                    "port": "[parameters('dashboardTargetPort')]"
                  },
                  "initialDelaySeconds": 15,
                  "periodSeconds": 30,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                }
              ]
            },
            {
              "name": "server",
              "image": "[parameters('serverImage')]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              },
              "env": [
                {
                  "name": "NODE_ENV",
                  "value": "production"
                },
                {
                  "name": "BETTER_AUTH_URL",
                  "value": "[parameters('dashboardUrl')]"
                },
                {
                  "name": "DASHBOARD_URL",
                  "value": "[parameters('dashboardUrl')]"
                },
                {
                  "name": "SERVER_URL",
                  "value": "[parameters('dashboardUrl')]"
                },
                {
                  "name": "WEBSITE_URL",
                  "value": "[parameters('websiteUrl')]"
                },
                {
                  "name": "CORS_ORIGIN",
                  "value": "[variables('corsOriginValue')]"
                },
                {
                  "name": "DEBUG_PERFORMANCE",
                  "value": "[parameters('debugPerformance')]"
                },
                {
                  "name": "PORT",
                  "value": "[string(parameters('serverTargetPort'))]"
                },
                {
                  "name": "HOST",
                  "value": "127.0.0.1"
                },
                {
                  "name": "DATABASE_URL",
                  "secretRef": "database-url"
                },
                {
                  "name": "BETTER_AUTH_SECRET",
                  "secretRef": "better-auth-secret"
                },
                {
                  "name": "BETTER_AUTH_API_KEY",
                  "secretRef": "better-auth-api-key"
                },
                {
                  "name": "GOOGLE_CLIENT_ID",
                  "secretRef": "google-client-id"
                },
                {
                  "name": "GOOGLE_CLIENT_SECRET",
                  "secretRef": "google-client-secret"
                },
                {
                  "name": "LINKEDIN_CLIENT_ID",
                  "secretRef": "linkedin-client-id"
                },
                {
                  "name": "LINKEDIN_CLIENT_SECRET",
                  "secretRef": "linkedin-client-secret"
                },
                {
                  "name": "CLOUDINARY_CLOUD_NAME",
                  "secretRef": "cloudinary-cloud-name"
                },
                {
                  "name": "CLOUDINARY_API_KEY",
                  "secretRef": "cloudinary-api-key"
                },
                {
                  "name": "CLOUDINARY_API_SECRET",
                  "secretRef": "cloudinary-api-secret"
                },
                {
                  "name": "RESEND_API_KEY",
                  "secretRef": "resend-api-key"
                },
                {
                  "name": "RESEND_EMAIL_FROM",
                  "secretRef": "resend-email-from"
                },
                {
                  "name": "RESEND_EMAIL_REPLY_TO",
                  "secretRef": "resend-email-reply-to"
                },
                {
                  "name": "AI_GATEWAY_API_KEY",
                  "secretRef": "ai-gateway-api-key"
                }
              ],
              "probes": [
                {
                  "type": "Startup",
                  "tcpSocket": {
                    "port": "[parameters('serverTargetPort')]"
                  },
                  "initialDelaySeconds": 5,
                  "periodSeconds": 5,
                  "timeoutSeconds": 3,
                  "failureThreshold": 24
                },
                {
                  "type": "Liveness",
                  "tcpSocket": {
                    "port": "[parameters('serverTargetPort')]"
                  },
                  "initialDelaySeconds": 15,
                  "periodSeconds": 30,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": "[parameters('appMinReplicas')]",
            "maxReplicas": "[parameters('appMaxReplicas')]"
          }
        }
      },
      "tags": "[variables('mergedTags')]",
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]",
        "[resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), 'database-url')]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('postgresServerName'))]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers/databases', parameters('postgresServerName'), parameters('postgresDatabaseName'))]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers/firewallRules', parameters('postgresServerName'), 'AllowAllAzureServices')]"
      ]
    }
  ],
  "outputs": {
    "containerRegistryName": {
      "type": "string",
      "value": "[parameters('containerRegistryName')]"
    },
    "containerRegistryLoginServer": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName')), '2023-07-01').loginServer]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[parameters('keyVaultName')]"
    },
    "containerAppsEnvironmentId": {
      "type": "string",
      "value": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]"
    },
    "containerAppsEnvironmentDefaultDomain": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName')), '2024-03-01').defaultDomain]"
    },
    "appContainerAppName": {
      "type": "string",
      "value": "[parameters('appName')]"
    },
    "appDefaultUrl": {
      "type": "string",
      "value": "[if(parameters('deployApps'), format('https://{0}', reference(resourceId('Microsoft.App/containerApps', parameters('appName')), '2024-03-01').configuration.ingress.fqdn), '')]"
    },
    "postgresFqdn": {
      "type": "string",
      "value": "[if(parameters('deployPostgres'), reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('postgresServerName')), '2024-08-01').fullyQualifiedDomainName, '')]"
    }
  }
}
