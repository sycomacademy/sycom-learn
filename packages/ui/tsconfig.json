{
  "extends": "@sycom/config/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "@sycom/ui/*": ["./src/*"],
      "@sycom/components/*": ["./src/components/*"],
      "@sycom/components/ui/*": ["./src/components/*"],
      "@sycom/components/tiptap/*": ["./src/components/tiptap/*"],
      "@sycom/hooks/*": ["./src/hooks/*"],
      "@sycom/lib/*": ["./src/lib/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "stories/**/*.ts",
    "stories/**/*.tsx",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
