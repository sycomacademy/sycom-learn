{
  "name": "@sycom/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:seed:categories": "bun run src/seed/run-categories.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@sycom/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "pg": "^8.22.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sycom/config": "workspace:*",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
