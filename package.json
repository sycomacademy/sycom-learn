{
  "name": "sycom",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "@types/bun": "^1.3.14",
      "hono": "^4.12.27",
      "@trpc/server": "^11.18.0",
      "better-auth": "1.6.22",
      "lucide-react": "^1.22.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "@trpc/client": "^11.18.0",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.1",
      "drizzle-orm": "^0.45.2",
      "react-hook-form": "^7.80.0",
      "@hookform/resolvers": "^5.4.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo -F dashboard -F server dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test": "turbo test",
    "storybook:ui": "turbo -F @sycom/ui storybook",
    "build-storybook:ui": "turbo -F @sycom/ui build-storybook",
    "dev:dashboard": "turbo -F dashboard dev",
    "dev:website": "turbo -F website dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @sycom/db db:push",
    "db:studio": "turbo -F @sycom/db db:studio",
    "db:generate": "turbo -F @sycom/db db:generate",
    "db:migrate": "turbo -F @sycom/db db:migrate",
    "check": "oxlint && oxfmt --write",
    "dev:emails": "turbo -F @sycom/emails dev",
    "update-deps": "bun run scripts/update-deps.ts && bun install"
  },
  "dependencies": {
    "@sycom/db": "workspace:*",
    "@sycom/env": "workspace:*",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/router-plugin": "^1.168.18",
    "dotenv": "catalog:",
    "vite": "^8.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sycom/config": "workspace:*",
    "@types/bun": "^1.3.14",
    "cloudinary": "^2.10.0",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.71.0",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.12"
}
